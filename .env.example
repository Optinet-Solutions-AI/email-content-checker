# ── Unique-Content Email Dashboard — environment template ──
# Copy to `.env` at the REPO ROOT (not inside web/). Never commit the real .env.

# Supabase (Postgres + server writes). Service role key — server-only, keep secret.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Google Gemini (AI copy — fills the [[ai_slots]]). Free tier ~1,500 req/day.
GOOGLE_GENAI_API_KEY=
GOOGLE_GENAI_MODEL=gemini-2.5-flash

# Global send kill-switch. ISO timestamp; while in the future, ALL sends are halted.
EMAIL_SENDING_PAUSED_UNTIL=

# Runtime
APP_ENV=development
PORT=3000
LOG_LEVEL=info

# Sender mailboxes are NOT env vars — they live in the `email_accounts` table,
# connected/tested/removed from the dashboard (SMTP host/port/user/pass).
